generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model TransactionLog {
  id         String   @id @default(cuid())
  userId     String
  type       String
  amount     Float
  status     String
  referenceId String
  metadata   Json?
  createdAt  DateTime @default(now())
}
